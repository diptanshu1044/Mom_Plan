# Application
PORT=5000
NODE_ENV=development
# Optional: trace | debug | info | warn | error | fatal | silent (defaults: debug in dev, info in prod)
# LOG_LEVEL=debug
FRONTEND_URL=http://localhost:3000
ADMIN_FRONTEND_URL=http://localhost:3001
# Optional: comma-separated extra origins (staging, preview deploys, etc.)
# CORS_ORIGINS=https://staging.momplan.app,https://preview.vercel.app

# ─── Supabase PostgreSQL ────────────────────────────────────────
# Get from: https://supabase.com/dashboard → Project → Settings → Database
# DATABASE_URL = Pooled connection (Transaction mode, port 6543) — for Prisma runtime queries
# DIRECT_URL   = Direct connection (Session mode, port 5432) — for Prisma migrations only
DATABASE_URL=postgresql://postgres.PROJECT_REF:Helpsinglemoms01@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10
DIRECT_URL=postgresql://postgres.PROJECT_REF:Helpsinglemoms01@aws-0-REGION.pooler.supabase.com:5432/postgres

# Redis (use Upstash free tier: https://console.upstash.com)
REDIS_URL=redis://localhost:6379

# Authentication
JWT_SECRET=supersecretjwtkey_replace_in_production
JWT_REFRESH_SECRET=supersecretrefreshkey_replace_in_production
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_EXPIRES_DAYS=30

# AI / Anthropic API
ANTHROPIC_API_KEY=sk-ant-api03-placeholder-key

# Payments / Stripe
STRIPE_SECRET_KEY=sk_test_placeholder
STRIPE_WEBHOOK_SECRET=whsec_placeholder
STRIPE_PRICE_PARTNER_MONTHLY=price_partner_monthly
STRIPE_PRICE_PARTNER_ANNUAL=price_partner_annual
STRIPE_PRICE_NETWORK_MONTHLY=price_network_monthly
STRIPE_PRICE_NETWORK_ANNUAL=price_network_annual
# Set to true to simulate successful payments without charging real cards
MOCK_STRIPE_PAYMENTS=true

# AWS S3 / File Storage
AWS_ACCESS_KEY_ID=placeholder_access_key
AWS_SECRET_ACCESS_KEY=placeholder_secret_key
S3_BUCKET_NAME=momplan-documents-dev
AWS_REGION=us-east-1

# Email / Resend
RESEND_API_KEY=re_placeholder
